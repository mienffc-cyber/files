# サーバー設定
PORT=8000

# MySQL 接続情報
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=genki_db

# JWT シークレット（本番では長くランダムな文字列に変更）
JWT_SECRET=genki_super_secret_key_change_in_production
JWT_EXPIRES_IN=24h

# CORS 許可オリジン（カンマ区切り）
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500
